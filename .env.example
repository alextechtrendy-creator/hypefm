# X API bearer token (Basic tier or higher).
# https://developer.x.com — create app, get bearer token.
X_BEARER_TOKEN=

# HuggingFace token, required for pyannote diarization model.
# Free at https://huggingface.co/settings/tokens
# Also accept model terms at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=

# Whisper model size: tiny, base, small, medium, large-v3
# large-v3 is best quality, ~3GB. Use "small" for faster CPU transcription.
WHISPER_MODEL=large-v3

# Compute device: cpu, cuda, auto
WHISPER_DEVICE=auto

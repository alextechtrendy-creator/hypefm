@property --hexagon-angle {
  syntax: "<angle>";
  initial-value: 0deg;
  inherits: false;
}
.hexagon-glow-border {
  --hexagon-angle: 0deg;
  background: conic-gradient(
    from var(--hexagon-angle),
    rgb(var(--color-blue-3)),
    rgb(var(--color-blue-3) / 40%),
    rgb(var(--color-success-2)),
    rgb(var(--color-blue-3))
  );
  animation: hexagon-rotate 4s linear infinite;
}
@keyframes hexagon-rotate {
  from { --hexagon-angle: 0deg; }
  to { --hexagon-angle: 360deg; }
